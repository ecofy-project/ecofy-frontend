VITE_APP_DATA_MODE=mock
VITE_AUTH_CLIENT_ID=
VITE_APP_ENV=development
VITE_MOCK_SCENARIO=default
VITE_MOCK_AUTH_SCENARIO=success
VITE_MOCK_USER_ROLES=
VITE_MOCK_USER_PERMISSIONS=
VITE_MOCK_DELAY_MS=450

# Limite das validações preliminares de importação. O padrão (10 MB) acompanha o
# ambiente de desenvolvimento do ms-ingestion; em produção o serviço aceita 20 MB.
VITE_MAX_IMPORT_FILE_SIZE_BYTES=10485760

# Obrigatória somente quando VITE_APP_DATA_MODE=api.
VITE_API_GATEWAY_URL=
